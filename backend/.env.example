# ─── Core ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/portfolio
FRONTEND_URL=http://localhost:5173

# ─── Auth / Tokens ─────────────────────────────────────
JWT_SECRET=your_super_secret_access_token_key_change_me
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_change_me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7
REMEMBER_ME_TTL_DAYS=30
# Pepper added to OTP hashes (any long random string)
OTP_PEPPER=change_me_to_a_long_random_string

# Set true when serving frontend + backend on different domains over HTTPS
COOKIE_SECURE=false
# Cookie domain (leave blank for localhost)
COOKIE_DOMAIN=

# ─── Email (SMTP) ──────────────────────────────────────
# If these are left blank, OTP/emails are printed to the server console
# (dev fallback) so you can still test the full flow without a mail server.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Portfolio publisher <no-reply@yourapp.com>"

# ─── AI Portfolio Assistant (Phase 10) ─────────────────
# Optional. If unset, the chatbot uses a built-in offline (rule-based)
# fallback that answers from the portfolio data — no key required.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
